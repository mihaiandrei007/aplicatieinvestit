{
  "expo": {
    "name": "InvestPals",
    "slug": "investpals",
    "scheme": "investpals",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.investpals.app"
    },
    "android": {
      "package": "com.investpals.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0B0D"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://investpals-backend.onrender.com"
    }
  }
}
