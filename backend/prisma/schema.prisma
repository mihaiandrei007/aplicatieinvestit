// Schema de date InvestPals.
// Pleacă de la User / Instrument / Transaction (din „Portofoliu Virtual")
// și adaugă stratul social: Group, Membership, ActivityEvent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionSide {
  BUY
  SELL
}

enum MemberRole {
  OWNER
  MEMBER
}

/// Utilizator cu un singur portofoliu personal (bani virtuali).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// Null pentru conturile create prin OAuth (Google/Apple).
  passwordHash String?
  /// Identitate OAuth, dacă există (provider + subiect unic la provider).
  oauthProvider String?
  oauthSub      String?
  displayName  String
  /// Self-reported at signup: role (STUDENT_M/STUDENT_F/OTHER) and investing experience (NEW/SOME/PRO).
  role         String?
  experience   String?
  /// Numerar virtual disponibil (necheltuit pe instrumente).
  cash         Float    @default(10000)
  /// Capitalul de start, păstrat pentru calculul ROI.
  startingCash Float    @default(10000)
  /// Credite de tranzacționare (anti-overtrading + retenție). 1 credit / tranzacție.
  tradeCredits Int      @default(20)
  /// Streak de check-in zilnic.
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastCheckIn   String?
  streakFreezes Int     @default(0)
  createdAt    DateTime @default(now())

  transactions Transaction[]
  memberships  Membership[]
  ownedGroups  Group[]        @relation("GroupOwner")
  activity     ActivityEvent[]
  reactions    Reaction[]
  comments     Comment[]
  pushTokens   PushToken[]
  badges       Badge[]
  tournamentEntries TournamentEntry[]
  equitySnapshots   EquitySnapshot[]
  sentiments        Sentiment[]
  predictions       Prediction[]
  watchlist         Watchlist[]
  dailyEntries      DailyChallengeEntry[]

  @@unique([oauthProvider, oauthSub])
}

/// Instrument urmărit de un utilizator (pentru alerte de preț).
model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([symbol])
}

/// Provocarea zilnică: o singură acțiune pe zi, toți prezic aceeași direcție.
model DailyChallenge {
  id         String   @id @default(cuid())
  date       String   @unique
  symbol     String
  startPrice Float
  endPrice   Float?
  resultUp   Boolean?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())

  entries DailyChallengeEntry[]
}

model DailyChallengeEntry {
  id          String              @id @default(cuid())
  challengeId String
  userId      String
  direction   PredictionDirection
  correct     Boolean?
  createdAt   DateTime            @default(now())

  challenge DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

enum PredictionDirection {
  UP
  DOWN
}

enum PredictionStatus {
  PENDING
  WON
  LOST
}

/// „Predicție rapidă": pariu pe direcția unei acțiuni până la următorul tick.
model Prediction {
  id         String              @id @default(cuid())
  userId     String
  symbol     String
  direction  PredictionDirection
  stake      Float
  multiplier Float
  priceAtBet Float
  status     PredictionStatus    @default(PENDING)
  payout     Float               @default(0)
  createdAt  DateTime            @default(now())
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
}

/// Poziția curentă (BULLISH/BEARISH) a unui utilizator per simbol.
model Sentiment {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([symbol])
}

/// Token de notificare push (Expo) per dispozitiv.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("expo")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Instrument tranzacționabil (acțiune simulată).
model Instrument {
  id           String   @id @default(cuid())
  symbol       String   @unique
  name         String
  /// Parametri pentru simulatorul determinist de preț (lib/priceSim).
  basePrice    Float
  currentPrice Float
  volatility   Float    @default(0.2)
  drift        Float    @default(0.05)
  beta         Float    @default(1.0)
  /// Cât capital net mișcă prețul (cerere/ofertă). Mai mare = mai greu de mișcat.
  liquidity    Float    @default(500000)
  /// Sectorul/tema (pentru co-mișcare între stocuri).
  sector       String?
  /// Cât de mult urmează liderul sectorului (0 = lider/independent).
  correlation  Float    @default(0)
  currency     String   @default("USD")
  createdAt    DateTime @default(now())

  transactions Transaction[]
}

/// Time series of an instrument's price (for the history chart).
model PricePoint {
  id     String   @id @default(cuid())
  symbol String
  price  Float
  at     DateTime @default(now())

  @@index([symbol, at])
}

/// Știre FALSĂ (simulată) care a mișcat un instrument.
model News {
  id        String   @id @default(cuid())
  symbol    String?
  headline  String
  body      String   @default("")
  source    String   @default("")
  /// Impact semnat aplicat la preț (intern, nedezvăluit clientului).
  impact    Float
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([symbol, createdAt])
}

/// O cumpărare sau vânzare. Holdings & P&L se derivă din istoricul tranzacțiilor.
model Transaction {
  id           String          @id @default(cuid())
  userId       String
  instrumentId String
  side         TransactionSide
  quantity     Float
  /// Prețul de execuție per unitate.
  price        Float
  createdAt    DateTime        @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([instrumentId])
}

/// Grup de prieteni; se intră cu un cod de invitație.
model Group {
  id           String   @id @default(cuid())
  name         String
  inviteCode   String   @unique
  ownerId      String
  startingCash Float    @default(10000)
  createdAt    DateTime @default(now())

  owner       User            @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  activity    ActivityEvent[]
  tournaments Tournament[]
}

/// Apartenența unui utilizator la un grup (many-to-many cu metadate).
model Membership {
  id       String     @id @default(cuid())
  groupId  String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

/// Eveniment din feed-ul social. Emis la tranzacții, alăturări, insigne.
model ActivityEvent {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]

  @@index([groupId, createdAt])
}

/// Reacție (emoji) la un eveniment din feed. Un utilizator = o reacție per emoji.
model Reaction {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  event ActivityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, emoji])
  @@index([eventId])
}

/// Comentariu la un eveniment din feed.
model Comment {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  body      String
  createdAt DateTime @default(now())

  event ActivityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

/// Turneu pe perioadă fixă într-un grup (Etapa 4). ROI măsurat în fereastra turneului.
model Tournament {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  group   Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entries TournamentEntry[]

  @@index([groupId])
}

/// Înscrierea unui utilizator în turneu, cu capitalul de la momentul intrării.
model TournamentEntry {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  /// Capitalul (equity) la înscriere — baza pentru ROI-ul turneului.
  startEquity  Float
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

/// Insignă câștigată de un utilizator (un cod o singură dată).
model Badge {
  id        String   @id @default(cuid())
  userId    String
  code      String
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
}

/// Instantaneu de capital, pentru clasamentul ajustat la risc (Sharpe).
model EquitySnapshot {
  id        String   @id @default(cuid())
  userId    String
  equity    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
