// Schema de date InvestPals.
// Pleacă de la User / Instrument / Transaction (din „Portofoliu Virtual")
// și adaugă stratul social: Group, Membership, ActivityEvent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionSide {
  BUY
  SELL
}

enum MemberRole {
  OWNER
  MEMBER
}

/// Utilizator cu un singur portofoliu personal (bani virtuali).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  /// Null pentru conturile create prin OAuth (Google/Apple).
  passwordHash String?
  /// Identitate OAuth, dacă există (provider + subiect unic la provider).
  oauthProvider String?
  oauthSub      String?
  displayName  String
  /// Numerar virtual disponibil (necheltuit pe instrumente).
  cash         Float    @default(100000)
  /// Capitalul de start, păstrat pentru calculul ROI.
  startingCash Float    @default(100000)
  /// Credite de tranzacționare (anti-overtrading + retenție). 1 credit / tranzacție.
  tradeCredits Int      @default(20)
  /// Streak de check-in zilnic.
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastCheckIn   String?
  streakFreezes Int     @default(0)
  createdAt    DateTime @default(now())

  transactions Transaction[]
  memberships  Membership[]
  ownedGroups  Group[]        @relation("GroupOwner")
  activity     ActivityEvent[]
  reactions    Reaction[]
  comments     Comment[]
  pushTokens   PushToken[]
  badges       Badge[]
  tournamentEntries TournamentEntry[]
  equitySnapshots   EquitySnapshot[]
  academyProgress   AcademyProgress[]
  quizAttempts      QuizAttempt[]
  sentiments        Sentiment[]

  @@unique([oauthProvider, oauthSub])
}

/// Poziția curentă (BULLISH/BEARISH) a unui utilizator per simbol.
model Sentiment {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  value     String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
  @@index([symbol])
}

/// Token de notificare push (Expo) per dispozitiv.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("expo")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Instrument tranzacționabil (acțiune simulată).
model Instrument {
  id           String   @id @default(cuid())
  symbol       String   @unique
  name         String
  /// Parametri pentru simulatorul determinist de preț (lib/priceSim).
  basePrice    Float
  currentPrice Float
  volatility   Float    @default(0.2)
  drift        Float    @default(0.05)
  beta         Float    @default(1.0)
  /// Cât capital net mișcă prețul (cerere/ofertă). Mai mare = mai greu de mișcat.
  liquidity    Float    @default(500000)
  currency     String   @default("USD")
  createdAt    DateTime @default(now())

  transactions Transaction[]
}

/// Știre FALSĂ (simulată) care a mișcat un instrument.
model News {
  id        String   @id @default(cuid())
  symbol    String?
  headline  String
  /// Impact semnat aplicat la preț (ex. +0.07 = +7%).
  impact    Float
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([symbol, createdAt])
}

/// O cumpărare sau vânzare. Holdings & P&L se derivă din istoricul tranzacțiilor.
model Transaction {
  id           String          @id @default(cuid())
  userId       String
  instrumentId String
  side         TransactionSide
  quantity     Float
  /// Prețul de execuție per unitate.
  price        Float
  createdAt    DateTime        @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([instrumentId])
}

/// Grup de prieteni; se intră cu un cod de invitație.
model Group {
  id           String   @id @default(cuid())
  name         String
  inviteCode   String   @unique
  ownerId      String
  startingCash Float    @default(100000)
  createdAt    DateTime @default(now())

  owner       User            @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  activity    ActivityEvent[]
  tournaments Tournament[]
}

/// Apartenența unui utilizator la un grup (many-to-many cu metadate).
model Membership {
  id       String     @id @default(cuid())
  groupId  String
  userId   String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
}

/// Eveniment din feed-ul social. Emis la tranzacții, alăturări, insigne.
model ActivityEvent {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  type      String
  payload   Json
  createdAt DateTime @default(now())

  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  comments  Comment[]

  @@index([groupId, createdAt])
}

/// Reacție (emoji) la un eveniment din feed. Un utilizator = o reacție per emoji.
model Reaction {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  event ActivityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId, emoji])
  @@index([eventId])
}

/// Comentariu la un eveniment din feed.
model Comment {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  body      String
  createdAt DateTime @default(now())

  event ActivityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

/// Turneu pe perioadă fixă într-un grup (Etapa 4). ROI măsurat în fereastra turneului.
model Tournament {
  id        String   @id @default(cuid())
  groupId   String
  name      String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  group   Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entries TournamentEntry[]

  @@index([groupId])
}

/// Înscrierea unui utilizator în turneu, cu capitalul de la momentul intrării.
model TournamentEntry {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  /// Capitalul (equity) la înscriere — baza pentru ROI-ul turneului.
  startEquity  Float
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

/// Insignă câștigată de un utilizator (un cod o singură dată).
model Badge {
  id        String   @id @default(cuid())
  userId    String
  code      String
  awardedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
}

/// Instantaneu de capital, pentru clasamentul ajustat la risc (Sharpe).
model EquitySnapshot {
  id        String   @id @default(cuid())
  userId    String
  equity    Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Progresul unui utilizator în academie (o misiune finalizată o singură dată).
model AcademyProgress {
  id          String   @id @default(cuid())
  userId      String
  missionId   String
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
}

/// Rezultatul unei încercări de quiz.
model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  total     Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
