# Copiază în `.env` și completează valorile.

# Conexiune PostgreSQL (Prisma)
DATABASE_URL="postgresql://user:parola@localhost:5432/investpals?schema=public"

# Secret pentru semnarea JWT (folosește o valoare lungă, aleatorie în producție)
JWT_SECRET="schimba-ma-cu-un-secret-lung-si-aleator"

# Durata de valabilitate a token-ului
JWT_EXPIRES_IN="7d"

# Portul serverului HTTP
PORT=4000

# Capitalul virtual de start pentru fiecare utilizator nou
STARTING_CASH=100000

# Buget de tranzacții (anti-overtrading): credite de start + plafon
TRADE_CREDITS_START=20
TRADE_CREDITS_MAX=30

# Recompensă la promovarea unui quiz (cash virtual + credite)
QUIZ_REWARD_CASH=500
QUIZ_REWARD_CREDITS=2

# OAuth — client ID-urile (audiența așteptată în ID token)
GOOGLE_CLIENT_ID=""
APPLE_CLIENT_ID=""
